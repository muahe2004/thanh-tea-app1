<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        * {
            font-family: 'Poppins', sans-serif !important;
        }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="w-full">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-page="/Index">
                    MathMaster
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Index">Trang chủ</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/ChuongTrinhHoc">Chương trình học</a>
                        </li>

                        
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/TaiLieu">Tài liệu</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/TinTuc">Tin tức</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/LienHe">Liên hệ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Admin/Index">Admin</a>
                        </li>

                    </ul>

                </div>
            </div>
        </nav>
    </header>


    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>


    <footer class="border-top footer text-muted text-center p-3">
        © 2026 MathMaster - Học Toán 12 Online
    </footer>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>