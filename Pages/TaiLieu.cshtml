@page
@model WebApplication1.Pages.TaiLieuModel
@{
    ViewData["Title"] = "Tài liệu Toán 12";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - MathMaster</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', system-ui, sans-serif;
        }
    </style>
</head>
<body class="bg-gray-50">

    <!-- HEADER -->
    <header class="bg-white shadow-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 bg-blue-700 text-white rounded-2xl flex items-center justify-center text-3xl font-bold shadow-inner">π</div>
                <div>
                    <span class="text-3xl font-bold text-blue-700 tracking-tighter">Math</span>
                    <span class="text-3xl font-bold text-orange-500 tracking-tighter">Master</span>
                </div>
            </div>

            <nav class="hidden md:flex items-center gap-8 text-lg font-medium">
                <a href="/" class="nav-link text-gray-700 hover:text-blue-700">Trang chủ</a>
                <a asp-page="/KhoaHoc" class="nav-link text-gray-700 hover:text-blue-700">Khóa học</a>
                <a href="/#resources" class="nav-link text-gray-700 hover:text-blue-700">Tài liệu</a>
                <a href="/#news" class="nav-link text-gray-700 hover:text-blue-700">Tin tức</a>
                <a href="/#contact" class="nav-link text-gray-700 hover:text-blue-700">Liên hệ</a>
            </nav>

            <div class="flex items-center gap-4">
                <button onclick="showLoginModal()"
                        class="px-6 py-2.5 text-sm font-semibold text-blue-700 border-2 border-blue-700 rounded-3xl hover:bg-blue-50 transition">
                    Đăng nhập
                </button>
                <button onclick="window.location.href='/#courses'"
                        class="px-8 py-2.5 bg-gradient-to-r from-blue-700 to-orange-500 text-white text-sm font-semibold rounded-3xl hover:shadow-xl transition shadow-md">
                    Đăng ký học ngay
                </button>
                <button id="mobile-menu-btn" class="md:hidden text-3xl text-blue-700">
                    <i class="fa-solid fa-bars"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
            <div class="flex flex-col px-6 py-6 gap-5 text-lg font-medium">
                <a href="/" class="py-2">Trang chủ</a>
                <a asp-page="/KhoaHoc" class="py-2">Khóa học</a>
                <a href="/#resources" class="py-2">Tài liệu</a>
                <a href="/#news" class="py-2">Tin tức</a>
                <a href="/#contact" class="py-2">Liên hệ</a>
            </div>
        </div>
    </header>

    <!-- BANNER -->
    <section class="bg-blue-900 text-white py-20 text-center">
        <h1 class="text-5xl font-bold mb-6">Chương trình học Toán 12</h1>
        <p class="text-xl text-blue-200 max-w-2xl mx-auto">
            Lộ trình học Toán lớp 12 từ cơ bản đến nâng cao,
            giúp học sinh chinh phục kỳ thi THPT Quốc gia.
        </p>
    </section>

    <!-- NỘI DUNG CHƯƠNG TRÌNH -->
    <section class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid grid-cols-12 gap-8">
            <!-- SIDEBAR -->
            <div class="col-span-3 bg-white p-6 rounded-2xl shadow-md border border-blue-100">
                <h2 class="font-bold text-xl mb-4 text-blue-700">Toán 12 Kết nối tri thức</h2>
                <ul class="space-y-2 text-base text-gray-800">
                    <li class="bg-orange-500 text-white px-4 py-3 rounded-xl font-semibold shadow">
                        Giải SGK Toán 12 Kết nối tri thức
                    </li>
                    <li class="hover:text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg cursor-pointer transition">
                        Giải Toán 12 Tập 1
                    </li>
                    <li class="hover:text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg cursor-pointer transition">
                        Giải Toán 12 Tập 2
                    </li>
                </ul>
                <hr class="my-5">
                <h3 class="font-bold text-lg mb-4 text-blue-800">TÀI LIỆU TOÁN 12</h3>
                <ul class="space-y-2 text-gray-800">
                    <li><a asp-page="/DeCuong" class="block bg-orange-500 text-white px-4 py-3 rounded-xl font-semibold">ĐỀ CƯƠNG TOÁN 12</a></li>
                    <li><a asp-page="/DeGiuaHK1" class="block hover:text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg">ĐỀ GIỮA HK1 TOÁN 12</a></li>
                    <li><a asp-page="/DeHK1" class="block hover:text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg">ĐỀ HK1 TOÁN 12</a></li>
                    <li><a asp-page="/DeGiuaHK2" class="block hover:text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg">ĐỀ GIỮA HK2 TOÁN 12</a></li>
                    <li><a asp-page="/DeHK2" class="block hover:text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg">ĐỀ HK2 TOÁN 12</a></li>
                    <li><a asp-page="/DeKhaoSat" class="block hover:text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg">ĐỀ KHẢO SÁT TOÁN 12</a></li>
                    <li><a asp-page="/DeHSG" class="block hover:text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg">ĐỀ HSG TOÁN 12</a></li>
                    <li><a asp-page="/GiaoAn" class="block hover:text-blue-600 hover:bg-blue-50 px-3 py-2 rounded-lg">GIÁO ÁN TOÁN 12</a></li>
                </ul>
            </div>

            <!-- NỘI DUNG CHÍNH -->
            <div class="col-span-9 bg-gray-100 p-6 rounded-xl shadow-sm text-lg leading-8">
                <h1 class="text-2xl font-bold mb-6">Giải Toán 12 Kết nối tri thức (hay, chi tiết)</h1>

                <div class="aspect-video">
                    <iframe class="w-full h-full rounded-lg"
                            src="https://www.youtube.com/embed/DQtF9Nh6HJY"
                            title="YouTube video player"
                            frameborder="0"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            allowfullscreen>
                    </iframe>
                </div>

                <p class="text-gray-700 mb-6">
                    Bài giảng giúp học sinh hiểu rõ về tính đơn điệu của hàm số,
                    cách xác định cực trị và ứng dụng trong khảo sát đồ thị.
                </p>

                <h2 class="text-xl font-semibold mb-3">1. Tính đơn điệu của hàm số</h2>
                <p class="mb-4">Hàm số đồng biến trên khoảng (a, b) nếu f'(x) > 0 với mọi x thuộc khoảng đó.</p>

                <h2 class="text-xl font-semibold mb-3">2. Cực trị của hàm số</h2>
                <p class="mb-4">Điểm cực đại hoặc cực tiểu của hàm số được xác định thông qua đạo hàm.</p>

                <h2 class="text-xl font-semibold mt-6 mb-3">Bài tập luyện tập</h2>
                <ul class="list-disc pl-6 space-y-2">
                    <li>Cho hàm số y = x³ − 3x² + 1. Tìm khoảng đồng biến.</li>
                    <li>Tìm cực trị của hàm số y = x⁴ − 2x².</li>
                    <li>Khảo sát sự biến thiên của hàm số y = x³ − 3x.</li>
                </ul>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-blue-950 text-white py-16">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-4 gap-10">
            <div>
                <div class="flex items-center gap-3 text-white">
                    <div class="w-10 h-10 bg-white text-blue-950 rounded-2xl flex items-center justify-center text-4xl font-bold">π</div>
                    <div class="text-3xl font-bold">MathMaster</div>
                </div>
                <p class="mt-6 text-blue-200 text-sm leading-relaxed">
                    Nền tảng học Toán Lớp 12 trực tuyến chất lượng cao.<br>
                    Đồng hành cùng hơn 10.000 học sinh Việt Nam.
                </p>
            </div>
            <div>
                <div class="font-semibold text-lg mb-6">Liên kết nhanh</div>
                <ul class="space-y-3 text-blue-200">
                    <li><a href="/" class="hover:text-white">Trang chủ</a></li>
                    <li><a href="/#resources" class="hover:text-white">Tài liệu miễn phí</a></li>
                </ul>
            </div>
            <div>
                <div class="font-semibold text-lg mb-6">Chương trình học</div>
                <ul class="space-y-3 text-blue-200">
                    <li>Hàm số & Giải tích</li>
                    <li>Hình học không gian</li>
                    <li>Xác suất - Thống kê</li>
                </ul>
            </div>
            <div>
                <div class="font-semibold text-lg mb-6">Liên hệ</div>
                <div class="text-sm text-blue-200 space-y-2">
                    <div>Hotline: 0987 654 321</div>
                    <div>Email: info@mathmaster.edu.vn</div>
                </div>
            </div>
        </div>
        <div class="text-center text-blue-300 text-xs mt-16">
            © 2026 MathMaster - Nền tảng học Toán Lớp 12. All rights reserved.
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
